{
  "name": "landguard-backend",
  "version": "1.0.0",
  "description": "LANDGUARD Backend API - National Land Registry Platform for Ghana",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
