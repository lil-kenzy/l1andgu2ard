# LANDGUARD Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
MONGODB_URI=mongodb+srv://PRVER:Kenzera0551231300#@landguar.zi1uu1e.mongodb.net/?appName=Landguar
# For production: mongodb+srv://username:password@cluster.mongodb.net/landguard

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this-too
JWT_REFRESH_EXPIRE=30d

# Client URLs (for CORS)
CLIENT_URL=http://localhost:3000
MOBILE_URL=exp://localhost:19000

# Frontend URLs
FRONTEND_URL=https://your-domain.vercel.app
ADMIN_URL=https://admin.your-domain.com

# App
APP_NAME=LANDGUARD
SUPPORT_EMAIL=support@landguard.gov.gh
TRANSACTION_FEE_PERCENT=2

# Encryption key for sensitive fields (AES-256 - must be 32 chars)
ENCRYPTION_KEY=your-32-character-encryption-key!!

# AWS S3 Configuration (for file uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=landguard-bucket
AWS_S3_BUCKET_DOCUMENTS=landguard-documents
AWS_S3_BUCKET_MEDIA=landguard-media
AWS_CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@landguard.gov.gh

# SendGrid (transactional email - alternative to nodemailer)
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# Twilio (SMS OTP)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase Cloud Messaging (Push notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# Paystack (Payment gateway - Ghana)
PAYSTACK_SECRET_KEY=sk_live_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_live_your-paystack-public-key

# Google Maps (server-side geocoding)
GOOGLE_MAPS_API_KEY=your-google-maps-server-api-key

# GhanaPost GPS
GHANA_POST_API_KEY=your-ghana-post-api-key
GHANA_POST_BASE_URL=https://app.ghanapostgps.com/api/v1

# NIA Ghana Card Verification
GHANA_CARD_API_KEY=your-nia-ghana-card-api-key
GHANA_CARD_API_URL=https://api.nia.gov.gh/v1

# Lands Commission API
LANDS_COMMISSION_API_KEY=your-lands-commission-api-key
LANDS_COMMISSION_API_URL=https://api.lc.gov.gh/v1

# OCR Service (for document extraction)
OCR_API_KEY=your-ocr-space-or-google-vision-api-key
OCR_PROVIDER=google_vision

# Security
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Limits
MAX_FILE_SIZE=10485760
MAX_FILES_COUNT=10

# Redis (for caching - optional)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
