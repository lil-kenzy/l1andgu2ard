# LANDGUARD Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/landguard?retryWrites=true&w=majority

# JWT Configuration — RS256 (RSA asymmetric signing, recommended for production)
# Generate a key pair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the PEM contents below (replace literal newlines with \n):
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=30d
# NOTE: JWT_SECRET / JWT_REFRESH_SECRET (HMAC) are no longer used.
#       Remove them from your environment to avoid confusion.

# Client URLs (for CORS)
CLIENT_URL=http://localhost:3000
MOBILE_URL=exp://localhost:19000

# Frontend URLs
FRONTEND_URL=https://your-domain.vercel.app
ADMIN_URL=https://admin.your-domain.com

# App
APP_NAME=LANDGUARD
SUPPORT_EMAIL=support@landguard.gov.gh
TRANSACTION_FEE_PERCENT=2

# Encryption key for sensitive fields (AES-256 - must be 32 chars)
ENCRYPTION_KEY=your-32-character-encryption-key!!

# AWS S3 Configuration (for file uploads — encryption-at-rest via SSE-S3 AES256)
# Leave blank to use local-disk sandbox (files saved to uploads/ directory)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET_DOCUMENTS=landguard-documents
AWS_S3_BUCKET_MEDIA=landguard-media
AWS_CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net
# STORAGE_PROVIDER=s3|local  (default: s3 when creds present, else local)
STORAGE_PROVIDER=s3
# Presigned GET URL TTL in seconds (default: 3600 = 1 hour)
PRESIGNED_URL_EXPIRES=3600

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@landguard.gov.gh

# SendGrid (transactional email - alternative to nodemailer)
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# Hubtel SMS (OTP delivery via SMS — used when user picks the "sms" channel)
# Sign up at https://unity.hubtel.com → API → Credentials
# Register an alphanumeric Sender ID (e.g. LANDGUARD) under your account before going live.
HUBTEL_CLIENT_ID=your-hubtel-client-id
HUBTEL_CLIENT_SECRET=your-hubtel-client-secret
HUBTEL_SENDER_ID=LANDGUARD

# Firebase Cloud Messaging (Push notifications + FCM)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
# Leave blank to use sandbox mode (push logs to console, no real delivery)

# Paystack (Payment gateway - Ghana)
PAYSTACK_SECRET_KEY=sk_live_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_live_your-paystack-public-key

# Google Maps (server-side geocoding)
GOOGLE_MAPS_API_KEY=your-google-maps-server-api-key

# GhanaPost GPS
GHANA_POST_API_KEY=your-ghana-post-api-key
GHANA_POST_BASE_URL=https://app.ghanapostgps.com/api/v1

# NIA Ghana Card Verification
# When both vars are set, live calls are made to the NIA REST API.
# Leave blank to use the built-in sandbox mock (safe for development/CI).
NIA_API_URL=https://api.nia.gov.gh/v1
NIA_API_KEY=your-nia-api-key

# Lands Commission API
LANDS_COMMISSION_API_KEY=your-lands-commission-api-key
LANDS_COMMISSION_API_URL=https://api.lc.gov.gh/v1

# OCR Service (document text extraction + metadata)
# OCR_PROVIDER=ocr_space|google_vision  (default: ocr_space)
# Leave OCR_API_KEY blank to use sandbox mock (returns synthetic text)
OCR_PROVIDER=ocr_space
OCR_API_KEY=your-ocr-space-or-google-vision-api-key

# Security
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Limits
MAX_FILE_SIZE=10485760
MAX_FILES_COUNT=10

# Redis (for caching - optional)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
