EXPO_PUBLIC_BACKEND_URL=https://api.landguard.gov.gh/api
EXPO_PUBLIC_APP_NAME=Landguard
EXPO_PUBLIC_APP_VERSION=1.0.0

# Google Maps (required for map screens)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-for-android-ios

# Firebase (push notifications)
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id

# App Config
EXPO_PUBLIC_SUPPORT_EMAIL=support@landguard.gov.gh
EXPO_PUBLIC_TRANSACTION_FEE_PERCENT=2
EXPO_PUBLIC_GHANA_POST_API_KEY=your-ghana-post-api-key
